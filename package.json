{
    "name": "intelligit",
    "displayName": "IntelliGit",
    "description": "IntelliJ-style Git UI for VS Code with commit graph, commit details, shelf workflow, and file change explorer.",
    "version": "0.5.2",
    "publisher": "MaheshKok",
    "icon": "media/intelligit-icon.png",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/MaheshKok/IntelliGit"
    },
    "engines": {
        "vscode": "^1.96.0"
    },
    "categories": [
        "SCM Providers"
    ],
    "keywords": [
        "git",
        "intellij",
        "intellij git",
        "pycharm",
        "pycharm git",
        "intelligent git",
        "intelligit",
        "git client",
        "git gui",
        "commit graph",
        "git graph",
        "branch manager",
        "shelf",
        "stash",
        "source control",
        "log",
        "graph",
        "scm"
    ],
    "activationEvents": [
        "workspaceContains:.git",
        "onView:intelligit.commitGraph"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "intelligit",
                    "title": "IntelliGit",
                    "icon": "media/intelligit.svg"
                }
            ],
            "panel": [
                {
                    "id": "intelligitPanel",
                    "title": "IntelliGit",
                    "icon": "media/intelligit.svg"
                }
            ]
        },
        "views": {
            "intelligit": [
                {
                    "id": "intelligit.commitPanel",
                    "name": "Commit",
                    "type": "webview"
                },
                {
                    "id": "intelligit.mergeConflicts",
                    "name": "Merge Conflicts",
                    "when": "intelligit.hasMergeConflicts"
                },
                {
                    "id": "intelligit.fileCountBadge",
                    "name": "Changes",
                    "visibility": "hidden"
                }
            ],
            "intelligitPanel": [
                {
                    "id": "intelligit.commitGraph",
                    "name": "",
                    "type": "webview"
                }
            ]
        },
        "commands": [
            {
                "command": "intelligit.showGitLog",
                "title": "Show Git Log",
                "category": "IntelliGit",
                "icon": "$(git-commit)"
            },
            {
                "command": "intelligit.refresh",
                "title": "Refresh",
                "category": "IntelliGit",
                "icon": "$(refresh)"
            },
            {
                "command": "intelligit.filterByBranch",
                "title": "Filter by Branch",
                "category": "IntelliGit"
            },
            {
                "command": "intelligit.checkout",
                "title": "Checkout",
                "category": "IntelliGit"
            },
            {
                "command": "intelligit.newBranchFrom",
                "title": "New Branch from...",
                "category": "IntelliGit"
            },
            {
                "command": "intelligit.checkoutAndRebase",
                "title": "Checkout and Rebase onto Current",
                "category": "IntelliGit"
            },
            {
                "command": "intelligit.rebaseCurrentOnto",
                "title": "Rebase Current onto Selected",
                "category": "IntelliGit"
            },
            {
                "command": "intelligit.mergeIntoCurrent",
                "title": "Merge into Current",
                "category": "IntelliGit"
            },
            {
                "command": "intelligit.updateBranch",
                "title": "Update",
                "category": "IntelliGit"
            },
            {
                "command": "intelligit.pushBranch",
                "title": "Push",
                "category": "IntelliGit"
            },
            {
                "command": "intelligit.renameBranch",
                "title": "Rename...",
                "category": "IntelliGit"
            },
            {
                "command": "intelligit.deleteBranch",
                "title": "Delete",
                "category": "IntelliGit"
            },
            {
                "command": "intelligit.fileRollback",
                "title": "Rollback",
                "category": "IntelliGit"
            },
            {
                "command": "intelligit.fileJumpToSource",
                "title": "Jump to Source",
                "category": "IntelliGit"
            },
            {
                "command": "intelligit.fileDelete",
                "title": "Delete",
                "category": "IntelliGit"
            },
            {
                "command": "intelligit.fileShelve",
                "title": "Shelve Changes",
                "category": "IntelliGit"
            },
            {
                "command": "intelligit.fileShowHistory",
                "title": "Show History",
                "category": "IntelliGit"
            },
            {
                "command": "intelligit.compareWithRevision",
                "title": "Compare with Revision",
                "category": "IntelliGit",
                "icon": "$(git-commit)"
            },
            {
                "command": "intelligit.compareWithBranch",
                "title": "Compare with Branch",
                "category": "IntelliGit",
                "icon": "$(git-branch)"
            },
            {
                "command": "intelligit.commitFileCompareWithLocal",
                "title": "Compare with Local",
                "category": "IntelliGit",
                "icon": "$(diff)"
            },
            {
                "command": "intelligit.commitFileCherryPickChange",
                "title": "Cherry-pick Selected Change",
                "category": "IntelliGit",
                "icon": "$(git-commit)"
            },
            {
                "command": "intelligit.commitFileRevertChange",
                "title": "Revert Selected Change",
                "category": "IntelliGit",
                "icon": "$(discard)"
            },
            {
                "command": "intelligit.fileRefresh",
                "title": "Refresh",
                "category": "IntelliGit",
                "icon": "$(refresh)"
            },
            {
                "command": "intelligit.fileRefreshing",
                "title": "Refreshing...",
                "category": "IntelliGit",
                "icon": "$(sync~spin)",
                "enablement": "false"
            },
            {
                "command": "intelligit.openMergeConflict",
                "title": "Open Merge Conflict",
                "category": "IntelliGit",
                "icon": "$(go-to-file)"
            },
            {
                "command": "intelligit.detectJetBrainsMergeTool",
                "title": "Detect JetBrains Merge Tool",
                "category": "IntelliGit",
                "icon": "$(search)"
            },
            {
                "command": "intelligit.openMergeConflictInJetBrains",
                "title": "Open in JetBrains Merge Tool",
                "category": "IntelliGit",
                "icon": "$(link-external)"
            },
            {
                "command": "intelligit.conflictAcceptYours",
                "title": "Accept Yours",
                "category": "IntelliGit",
                "icon": "$(arrow-left)"
            },
            {
                "command": "intelligit.conflictAcceptTheirs",
                "title": "Accept Theirs",
                "category": "IntelliGit",
                "icon": "$(arrow-right)"
            },
            {
                "command": "intelligit.mergeConflictsRefresh",
                "title": "Refresh",
                "category": "IntelliGit",
                "icon": "$(refresh)"
            },
            {
                "command": "intelligit.openConflictSession",
                "title": "Open Conflict Session",
                "category": "IntelliGit",
                "icon": "$(diff-multiple)"
            }
        ],
        "submenus": [
            {
                "id": "intelligit.editorContext",
                "label": "IntelliGit",
                "icon": "$(git-branch)"
            }
        ],
        "menus": {
            "editor/context": [
                {
                    "submenu": "intelligit.editorContext",
                    "when": "resourceScheme == file",
                    "group": "navigation@9"
                }
            ],
            "intelligit.editorContext": [
                {
                    "command": "intelligit.compareWithRevision",
                    "when": "resourceScheme == file",
                    "group": "1_compare@1"
                },
                {
                    "command": "intelligit.compareWithBranch",
                    "when": "resourceScheme == file",
                    "group": "1_compare@2"
                }
            ],
            "view/title": [
                {
                    "command": "intelligit.refresh",
                    "when": "view == intelligit.commitGraph",
                    "group": "navigation"
                },
                {
                    "command": "intelligit.fileRefresh",
                    "when": "view == intelligit.commitPanel && !intelligit.commitPanel.refreshing",
                    "group": "navigation"
                },
                {
                    "command": "intelligit.fileRefreshing",
                    "when": "view == intelligit.commitPanel && intelligit.commitPanel.refreshing",
                    "group": "navigation"
                },
                {
                    "command": "intelligit.mergeConflictsRefresh",
                    "when": "view == intelligit.mergeConflicts",
                    "group": "navigation"
                },
                {
                    "command": "intelligit.openConflictSession",
                    "when": "view == intelligit.mergeConflicts",
                    "group": "navigation@2"
                }
            ],
            "view/item/context": [
                {
                    "command": "intelligit.conflictAcceptYours",
                    "when": "view == intelligit.mergeConflicts && viewItem == intelligit.conflictFile",
                    "group": "inline@1"
                },
                {
                    "command": "intelligit.conflictAcceptTheirs",
                    "when": "view == intelligit.mergeConflicts && viewItem == intelligit.conflictFile",
                    "group": "inline@2"
                },
                {
                    "command": "intelligit.openMergeConflict",
                    "when": "view == intelligit.mergeConflicts && viewItem == intelligit.conflictFile",
                    "group": "navigation@1"
                },
                {
                    "command": "intelligit.openMergeConflictInJetBrains",
                    "when": "view == intelligit.mergeConflicts && viewItem == intelligit.conflictFile",
                    "group": "navigation@2"
                },
                {
                    "command": "intelligit.conflictAcceptYours",
                    "when": "view == intelligit.mergeConflicts && viewItem == intelligit.conflictFile",
                    "group": "1_actions@1"
                },
                {
                    "command": "intelligit.conflictAcceptTheirs",
                    "when": "view == intelligit.mergeConflicts && viewItem == intelligit.conflictFile",
                    "group": "1_actions@2"
                }
            ],
            "webview/context": [
                {
                    "command": "intelligit.fileRollback",
                    "when": "webviewId == 'intelligit.commitPanel' && webviewSection == 'file'",
                    "group": "1_actions@1"
                },
                {
                    "command": "intelligit.fileJumpToSource",
                    "when": "webviewId == 'intelligit.commitPanel' && webviewSection == 'file'",
                    "group": "1_actions@2"
                },
                {
                    "command": "intelligit.fileDelete",
                    "when": "webviewId == 'intelligit.commitPanel' && webviewSection == 'file'",
                    "group": "2_destructive@1"
                },
                {
                    "command": "intelligit.fileShelve",
                    "when": "webviewId == 'intelligit.commitPanel' && webviewSection == 'file'",
                    "group": "2_destructive@2"
                },
                {
                    "command": "intelligit.fileShowHistory",
                    "when": "webviewId == 'intelligit.commitPanel' && webviewSection == 'file'",
                    "group": "3_info@1"
                },
                {
                    "command": "intelligit.fileRefresh",
                    "when": "webviewId == 'intelligit.commitPanel' && !intelligit.commitPanel.refreshing",
                    "group": "3_info@2"
                }
                ,
                {
                    "command": "intelligit.commitFileCompareWithLocal",
                    "when": "(webviewId == 'intelligit.commitGraph' || webviewId == 'intelligit.commitFiles') && webviewSection == 'commitInfoFile'",
                    "group": "1_compare@1"
                },
                {
                    "command": "intelligit.commitFileCherryPickChange",
                    "when": "(webviewId == 'intelligit.commitGraph' || webviewId == 'intelligit.commitFiles') && webviewSection == 'commitInfoFile'",
                    "group": "2_apply@1"
                },
                {
                    "command": "intelligit.commitFileRevertChange",
                    "when": "(webviewId == 'intelligit.commitGraph' || webviewId == 'intelligit.commitFiles') && webviewSection == 'commitInfoFile'",
                    "group": "2_apply@2"
                }
            ]
        },
        "keybindings": [
            {
                "command": "intelligit.showGitLog",
                "key": "alt+9",
                "mac": "alt+9"
            }
        ],
        "configuration": {
            "title": "IntelliGit",
            "properties": {
                "intelligit.jetbrainsMergeTool.path": {
                    "type": "string",
                    "default": "",
                    "markdownDescription": "JetBrains IDE binary path/command (`pycharm`, `idea`, `webstorm`) or a macOS `.app` bundle path. IntelliGit auto-resolves `.app` bundles to the executable inside `Contents/MacOS`."
                },
                "intelligit.jetbrainsMergeTool.preferExternal": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "Prefer the external JetBrains merge tool when opening merge conflicts. Falls back to VS Code's internal merge editor if no JetBrains path is configured or launch fails."
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "bun scripts/build.js --production",
        "build": "bun scripts/build.js",
        "build:prod": "bun scripts/build.js --production",
        "watch": "bun scripts/watch.js",
        "format": "prettier --write \"src/**/*.{ts,tsx}\" \"scripts/**/*.js\"",
        "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"scripts/**/*.js\"",
        "lint": "eslint src",
        "typecheck:ext": "tsc -p tsconfig.json --noEmit",
        "typecheck:webview": "tsc -p tsconfig.webview.json --noEmit",
        "typecheck": "bun run typecheck:ext && bun run typecheck:webview",
        "test": "bun vitest run",
        "test:coverage": "bun vitest run --coverage",
        "test:watch": "bun vitest",
        "package": "vsce package --no-dependencies",
        "publish": "vsce publish --no-dependencies"
    },
    "devDependencies": {
        "@chakra-ui/react": "^2.8.2",
        "@emotion/react": "^11.11.3",
        "@emotion/styled": "^11.11.0",
        "@eslint/js": "^10.0.1",
        "@types/node": "^20.11.0",
        "@types/react": "^18.2.48",
        "@types/react-dom": "^18.2.18",
        "@types/vscode": "^1.96.0",
        "@typescript-eslint/eslint-plugin": "^7.0.0",
        "@typescript-eslint/parser": "^7.0.0",
        "@vitest/coverage-v8": "1.6.1",
        "@vscode/test-electron": "^2.3.9",
        "@vscode/vsce": "^2.22.0",
        "entities": "^6.0.1",
        "esbuild": "^0.20.0",
        "eslint": "^10.0.0",
        "eslint-plugin-react": "^7.37.5",
        "framer-motion": "^11.0.0",
        "globals": "^17.3.0",
        "jsdom": "^28.1.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-icons": "^5.5.0",
        "typescript": "^5.3.3",
        "typescript-eslint": "^8.55.0",
        "vitest": "^1.2.0"
    },
    "dependencies": {
        "jsonc-parser": "^3.3.1",
        "simple-git": "^3.22.0"
    }
}
